{
  "name": "pet-connect-be",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./dist/app.js",
    "build": "tsc",
    "build:watch": "tsc -w",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "dev:watch:compile": "tsc -w",
    "dev:watch:run": "nodemon --watch dist --exec node dist/app.js",
    "dev:watch": "concurrently \"npm:dev:watch:compile\" \"npm:dev:watch:run\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "debug": "~2.6.9",
    "dotenv": "^17.2.3",
    "express": "5.0.0",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "pg": "^8.16.3",
    "pug": "3.0.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
